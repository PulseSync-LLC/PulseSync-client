{
    "extends": "./tsconfig.json",
    "compilerOptions": {
        "composite": true,
        "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.node.tsbuildinfo",
        "lib": ["ES2025"],
        "module": "NodeNext",
        "moduleResolution": "NodeNext",
        "types": ["node"],
        "verbatimModuleSyntax": true
    },
    "include": [
        "declarations.d.ts",
        "vite.main.config.ts",
        "vite.preload.config.ts",
        "vite.renderer.config.ts",
        "forge.config.ts",
        "scripts/**/*.ts"
    ],
    "exclude": [
        "node_modules"
    ]
}
